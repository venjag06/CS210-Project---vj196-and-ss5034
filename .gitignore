# --- Data -------------------------------------------------------------------
# Raw Kaggle CSV is too big for GitHub; keep it local to the Codespace.
data/raw/*
!data/raw/.gitkeep
!data/raw/housing_sample.csv

# Interim and processed files are regenerated from raw data.
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Jupyter ----------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Environment secrets ----------------------------------------------------
.env
.env.local
*.pem
kaggle.json

# --- Editor / OS ------------------------------------------------------------
.vscode/settings.json
.idea/
.DS_Store
Thumbs.db

# --- Models / artifacts (can be regenerated) --------------------------------
models/*.pkl
models/*.joblib

# --- Logs -------------------------------------------------------------------
*.log
logs/